PORT=5000
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key
SUPABASE_JWT_SECRET=your_jwt_signing_secret_for_decoding_auth
